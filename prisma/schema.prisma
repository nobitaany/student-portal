datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Student {
  id                Int                 @id @default(autoincrement())
  year              Int                 // 1, 2, 3, 4
  semester          Int                 // 1 to 8
  course            String              // e.g., "B.Sc. (Hons.) Computer Science"
  rollNumber        String              @unique
  password          String              // Defaulted to cvs@1234
  selections        StudentSelection[]
}

model Subject {
  id                Int                 @id @default(autoincrement())
  type              String              // "GE", "DSE", "SEC", "VAC"
  name              String
  maxCapacity       Int                 @default(60)
  enrolledCount     Int                 @default(0)
  targetYear        Int                 // 1, 2, 3, 4
  targetSemester    Int                 // Specific semester availability
  courseSpecific    String?             // Null if common to all courses, set to course name if DSE
  selections        StudentSelection[]
}

model StudentSelection {
  id                Int                 @id @default(autoincrement())
  studentId         Int
  subjectId         Int
  category          String              // "GE", "DSE", "SEC", "VAC"
  student           Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject           Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, category])       // Guarantees only ONE subject per category per student
}